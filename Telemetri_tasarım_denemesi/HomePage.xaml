<Page
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telemetri_tasarım_denemesi"
      xmlns:Wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf" x:Class="Telemetri_tasarım_denemesi.HomePage"
      mc:Ignorable="d" 
      FontFamily="Segoe UI Semibold"
      d:DesignHeight="800" d:DesignWidth="1300"
      Loaded="HomePage_Loaded"
      Title="HomePage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="353*"/>
            <RowDefinition Height="347*"/>
        </Grid.RowDefinitions>
        <Border CornerRadius="20" BorderThickness="0" Height="70" Width="385" HorizontalAlignment="Left" Margin="10,15,0,15"/>
        <TextBlock Foreground="#E2E8F0" HorizontalAlignment="Center"  TextWrapping="Wrap" Text="   Asena Telemetri Ana Ekran " VerticalAlignment="Center" FontSize="30" Width="1300"/>


        <Wpf:WebView2 HorizontalAlignment="Left" Height="700" Grid.Row="1" VerticalAlignment="Bottom" Width="1300" Source="https://solarteamestu.com" Grid.RowSpan="2" ZoomFactor="0.8"/>
        <TextBlock x:Name="VersionLabel" Foreground="#E2E8F0" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="Version" VerticalAlignment="Center" FontSize="30" Width="82" Margin="1148,0,0,0" Height="40"/>


    </Grid>
</Page>
