<Page x:Class="Telemetri.Graph_Page"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telemetri"
      Loaded="GraphPage_Loaded"
      Unloaded="GraphPage_Unloaded"
      mc:Ignorable="d"
      FontFamily="Segoe UI Semibold"
      d:DesignHeight="800" d:DesignWidth="1300"
      Title="Graph_Page">

    <Grid>
        <Grid.RowDefinitions>
        <RowDefinition Height="100"/>
        <RowDefinition Height="200"/>
        <RowDefinition Height="200"/>
        <RowDefinition Height="200"/>
        <RowDefinition Height="100"/>
        </Grid.RowDefinitions>
        <Border CornerRadius="20" BorderThickness="0" Height="70" Width="490" HorizontalAlignment="Left" Margin="10,15,0,15"/>
        <TextBlock Foreground="#E2E8F0" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="   Asena Telemetri Grafik Takip Ekranı" VerticalAlignment="Center" FontSize="30"/>
     
        <Border Grid.Row="1" BorderBrush="#3D3D4E" BorderThickness="1" Background="#262835" CornerRadius="20" Margin="150, 20, 150, 20">
            <Border Margin="20, 20, 20, 20">

            </Border>
        </Border>
        <Border Grid.Row="2" BorderBrush="#3D3D4E" BorderThickness="1" Background="#262835" CornerRadius="20" Margin="150, 20, 150, 20">
            <Border Margin="20, 20, 20, 20">
                
            </Border>
        </Border>
        <Border Grid.Row="3" BorderBrush="#3D3D4E" BorderThickness="1" Background="#262835" CornerRadius="20" Margin="150, 20, 150, 20">
            <Border Margin="20, 20, 20, 20">
                
            </Border>
        </Border>
    </Grid>
</Page>
