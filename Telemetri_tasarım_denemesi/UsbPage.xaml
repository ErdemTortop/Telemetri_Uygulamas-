<Page x:Class="Telemetri_tasarım_denemesi.UsbPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telemetri_tasarım_denemesi"
      Loaded="UsbPage_Loaded"
      mc:Ignorable="d"
      FontFamily="Segoe UI Semibold"
      d:DesignHeight="800" d:DesignWidth="1300"
      Title="UsbPage">





    <Page.Resources>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Border CornerRadius="20"  BorderThickness="0" Height="70" Width="470" HorizontalAlignment="Left" Margin="10,15,0,15"/>
        <TextBlock Foreground="#E2E8F0" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="   Asena Telemetri Bağlantı Ayarları" VerticalAlignment="Center" FontSize="30" FontWeight="SemiBold"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition />
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="166"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="166"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="166"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Background="#262835" CornerRadius="20"  BorderThickness="0" Grid.Row="1" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="PortBaglanButon" Click="PortBaglanButon_Click">
                        <TextBlock  TextWrapping="Wrap" Foreground="#E2E8F0" Text="Bağlan" FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>

                <Border Background="#262835" CornerRadius="20" BorderThickness="0" Grid.Row="3" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="PortBaglantıIptalButon" Click="PortIptalButon_Click" >
                        <TextBlock  Grid.Row="3" TextWrapping="Wrap" Foreground="#E2E8F0" Text="Bağlantıyı Kes" FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>
            </Grid>
            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="500"/>
                    <RowDefinition Height="150" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="225"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Row="2" Grid.Column="1" CornerRadius="20" Background="#262835" BorderThickness="1" BorderBrush="#3D3D4E" Width="100" Height="50" HorizontalAlignment="Left" >
                        <TextBlock TextWrapping="Wrap" Foreground="#E2E8F0" Text="Bağlantı Durumu" FontSize="16" HorizontalAlignment="Center" FontWeight="Light"/>
                    </Border>
                    <Border Grid.Row="2" Grid.Column="2" CornerRadius="20" Background="#262835" BorderThickness="1" BorderBrush="#3D3D4E" Width="200" Height="80" HorizontalAlignment="Right">
                        <Label  x:Name="BaglantıDurumuLblRenk" Background="#E05C5C" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Height="40" />
                    </Border>
                </Grid>
                <Border Height="350" Width="525" Grid.Row="1" CornerRadius="20" Background="#262835" BorderThickness="1" BorderBrush="#3D3D4E">
                    <!--Port ve rate yazılarının altının tamamı-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="275"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0*"/>
                            <RowDefinition Height="175"/>
                            <RowDefinition Height="175"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="2">
                            <TextBlock Text="Port :" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground=" #E2E8F0" FontWeight="Light" />
                        </Border>
                        <Border Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Rate :" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground=" #E2E8F0" FontWeight="Light" />
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"  >
                            <ComboBox  FontSize="20" x:Name="PortComboBox" Margin="40,70,40,70" Foreground="#14191F" FontWeight="Light" OpacityMask="#FF14191F" ContextMenuOpening="PortsSelectionOpened"  />
                        </Border>
                        <Border Grid.Row="2" Grid.Column="1" >
                            <ComboBox x:Name="RateBox" Margin="40,70,40,70" Background="#E2E8F0" FontWeight="Light"  Foreground="#14191F" FontSize="20"/>
                        </Border>
                    </Grid>

                </Border>

            </Grid>
            <CheckBox x:Name="SpecialCheckbox" Content="açılma sayfası" HorizontalAlignment="Left" Margin="0,660,0,0" VerticalAlignment="Top" Grid.Column="1" Checked="CheckBox_Checked" BorderBrush="Black" Foreground="White" Background="White" MouseEnter="CheckBox_MouseEnter" MouseLeave="SpecialCheckbox_MouseLeave" Unchecked="SpecialCheckbox_Unchecked"/>
        </Grid>

    </Grid>
</Page>
