<Page x:Class="Telemetri_tasarım_denemesi.DataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telemetri_tasarım_denemesi"
      mc:Ignorable="d" 
      Loaded="DataPage_Loaded"
      Unloaded="DataPage_Unloaded"
      FontFamily="Segoe UI Semibold"
      d:DesignHeight="800" d:DesignWidth="1300"
      Title="DataPage">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border CornerRadius="20" BorderThickness="0" Height="70" Width="490" HorizontalAlignment="Left" Margin="10,15,0,15"/>
        <TextBlock Foreground="#E2E8F0" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="   Asena Telemetri Veri İzleme Ekranı" VerticalAlignment="Center" FontSize="30"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="175"/>
                </Grid.RowDefinitions>

                <Border  Grid.Row="1" CornerRadius="20"  Width="180" Height="50" Margin="0,100,0,0" HorizontalAlignment="Left" >
                    <TextBlock Text="Enerji İstatistikleri" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>

                <Border Grid.Row="2" BorderBrush="#3D3D4E" BorderThickness="1" Background="#262835" CornerRadius="20">

                    <Label x:Name="whLbl" Content="00 wh" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />

                </Border>


            </Grid>

            <Grid Grid.Column="3">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="300" />
                    <RowDefinition Height="175"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="1"  CornerRadius="20"  Width="190" Height="50" Margin="0,37,0,0" HorizontalAlignment="Left" >
                    <TextBlock Text="Batarya İstatistikleri" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>

                <Border Grid.Row="2" Background="#262835" BorderBrush="#3D3D4E" BorderThickness="1" CornerRadius="20">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Label x:Name="DereceLbl" Grid.Row="0" Content="00 °C" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        <Label x:Name="VoltajLbl" Grid.Row="1" Content="00 V" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />

                    </Grid>

                </Border>

            </Grid>

            <Grid Grid.Column="5">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition Height="130"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="20" HorizontalAlignment="Left">
                            <TextBlock Text="DeBug İstatistikleri" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Row="1" Background="#262835" BorderBrush="#3D3D4E" BorderThickness="1" CornerRadius="20">
                            <Label x:Name="PaketKaybi" Content="Kaybedilen Paket" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>

                </Border>
                <Border  Grid.Row="1" CornerRadius="20"  Width="160" Height="50" Margin="0,100,0,0" HorizontalAlignment="Left" >
                    <TextBlock Text="Hız İstatistikleri" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>

                <Border Grid.Row="2" Background="#262835" BorderBrush="#3D3D4E" BorderThickness="1" CornerRadius="20">
                    <Label x:Name="HizLbl" Content="00 km/h" Foreground="#E2E8F0" FontSize="20" FontWeight="Light" VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>

            </Grid>

        </Grid>

    </Grid>

</Page>
